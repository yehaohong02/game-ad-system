# ==================== 应用配置 ====================
APP_PORT=8000

# ==================== ClickHouse 配置 ====================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=game_ads

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== Meta Ads API ====================
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxx
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret

# ==================== AppsFlyer API ====================
APPSFLYER_API_TOKEN=your_appsflyer_token
APPSFLYER_APP_ID=your_app_id

# ==================== OpenAI API ====================
OPENAI_API_KEY=sk-xxxxx

# ==================== 安全配置 ====================
DAILY_BUDGET_LIMIT=10000.00
BID_INCREASE_MAX_RATIO=2.0

# ==================== Airflow 配置 ====================
AIRFLOW_PORT=8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_EMAIL=admin@example.com
AIRFLOW_SECRET_KEY=your-secret-key-change-in-production
